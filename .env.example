# ─────────────────────────────────────────────────────────────
#  NEXUS DASHBOARD — environment configuration
#  Copy this file to ".env" and fill in what you want to use.
#  Everything is optional except the login + session secret.
# ─────────────────────────────────────────────────────────────

# ── Auth (your private login) ───────────────────────────────
DASHBOARD_EMAIL=michel.bouckaert@hotmail.com
DASHBOARD_PASSWORD=Bouckaert52
# Change this to a long random string before hosting publicly:
SESSION_SECRET=change-me-to-a-long-random-string
PORT=3000

# ── AI chat widgets (live, server-side keys) ────────────────
# Add only the ones you want active. Empty = widget shows a
# "connect" state instead of erroring.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── News widget (live RSS) ──────────────────────────────────
# Comma-separated RSS/Atom URLs. Leave blank to use defaults.
NEWS_FEEDS=

# ── Goodreads reading progress (live RSS) ───────────────────
# Goodreads no longer issues API keys, but per-shelf RSS works.
# Goodreads > My Books > (shelf) > scroll down > RSS link.
GOODREADS_RSS_URL=

# ── Spotify ─────────────────────────────────────────────────
# Option A (recommended): full integration — sign in and pick any
# of YOUR playlists in the widget. Register an app at
# https://developer.spotify.com/dashboard (see README).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback
#
# Option B (simple): just embed ONE fixed playlist, no sign-in.
# A share link OR URI both work:
#   https://open.spotify.com/playlist/37i9dQZF1DXcBWIGoYBM5M
SPOTIFY_EMBED_URI=

# ── Outlook mail + calendar (Microsoft Graph) ───────────────
# Register an app at https://entra.microsoft.com (see README),
# then connect from the mail widget. Supports two accounts
# (professional + personal) via the in-app "Connect" buttons.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common
MS_REDIRECT_URI=http://localhost:3000/auth/ms/callback

# ── iCloud reminders + calendar (CalDAV) ────────────────────
# Apple ID + an app-specific password from appleid.apple.com
# (Sign-In & Security → App-Specific Passwords). When set, the
# Reminders widget and the iCloud half of the Agenda go live.
ICLOUD_USERNAME= 
ICLOUD_APP_PASSWORD= 

# ── Integration hooks (documented in README, not wired yet) ──
# Outlook mail + calendar  -> Microsoft Graph (MS365 connector)
# iCloud reminders + agenda -> CalDAV
# Finance (BNP Paribas Fortis) -> GoCardless Bank Account Data
# Website traffic -> Plausible / Umami / GA4 / Cloudflare
